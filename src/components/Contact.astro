                <a href="https://linkedin.com/in/winterx64" target="_blank" class="flex items-center gap-4 p-4 rounded-lg bg-white/5 hover:bg-white/10 transition-colors group">
                    <i class="fa-brands fa-linkedin group-hover:scale-110 transition-transform w-5"></i>
                    <span class="text-primary">@winterx64</span>
