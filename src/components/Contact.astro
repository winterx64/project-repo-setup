<section id="contact" class="max-w-6xl mx-auto px-6 md:px-8 lg:px-0 py-20">
    <div class="mb-12">
        <h2 class="text-3xl font-bold text-primary mb-4">Get In Touch</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
        <div class="p-8 rounded-2xl glass">
            <h4 class="font-semibold text-xl text-primary mb-4">
                Let's Connect
            </h4>
            <p class="text-secondary mb-6 leading-relaxed text-sm">
                I'm always open to discussing new opportunities, interesting
