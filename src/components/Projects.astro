---

---

<section id="projects" class="max-w-6xl mx-auto px-6 md:px-8 lg:px-0 py-20">
  <div class="mb-12">
    <h2 class="text-3xl font-bold text-primary mb-4">Projects That Matter</h2>
    <p class="text-secondary leading-relaxed text-sm max-w-2xl">
      A selection of my work that showcases my skills in web development,
      hardware integration, and innovative solutions. Each project reflects my
      passion for technology and problem-solving.
    </p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
    <!-- DropaNote -->
    <article class="p-6 rounded-2xl glass shadow-lg card-tilt">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h3 class="font-semibold text-xl text-primary mb-2">DropaNote</h3>
          <p class="text-sm text-tertiary">
            Lightweight embeddable feedback collection tool.
          </p>
        </div>
      </div>
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-4">
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >Flask</span
        >
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >Supabase</span
        >
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >Python</span
        >
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >Tailwind CSS</span
        >
      </div>
      <p class="text-secondary mb-6 leading-relaxed text-sm">
        Create embeddable forms, view submissions on a responsive dashboard, and
        manage apps quickly. Built to be simple and privacy-friendly.
      </p>

      <div class="flex gap-3">
        <a
          href="https://dropanote.onrender.com/"
          target="_blank"
          class="px-4 py-2 rounded-lg bg-white/10 text-primary text-sm hover:bg-white/15 transition-colors"
        >
          Live Demo
        </a>
        <a
          href="https://github.com/winterx64/dropanote"
          target="_blank"
          class="px-4 py-2 rounded-lg border border-white/20 text-secondary text-sm hover:text-primary hover:border-white/30 transition-colors"
        >
          Source
        </a>
      </div>
    </article>

    <!-- CubeSat payload -->
    <article class="p-6 rounded-2xl glass shadow-lg card-tilt">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h3 class="font-semibold text-xl text-primary mb-2">
            Payload for CubeSat
          </h3>
          <p class="text-sm text-tertiary">
            DIY spectrometer using Raspberry Pi + Arducam.
          </p>
        </div>
      </div>
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-4">
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >Raspberry Pi</span
        >
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >Arducam</span
        >
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >Arduino UNO</span
        >
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >Lidar</span
        >
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >Python</span
        >
      </div>
      <p class="text-secondary mb-6 leading-relaxed text-sm">
        Proof-of-concept spectrometer for material analysis in low-orbit
        scenarios. with object detection capabilities using Lidar and camera
      </p>

      <div class="flex gap-3">
        <a
          href="#contact"
          class="px-4 py-2 rounded-lg bg-white/10 text-primary text-sm hover:bg-white/15 transition-colors"
        >
          Learn More
        </a>
      </div>
    </article>

    <!-- VSCode Theme -->
    <article class="p-6 rounded-2xl glass shadow-lg card-tilt">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h3 class="font-semibold text-xl text-primary mb-2">
            WinterIsCoding
          </h3>
          <p class="text-sm text-tertiary">
            Modern dark theme with multiple variants for VSCode.
          </p>
        </div>
      </div>
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-4">
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >Marketplace</span
        >
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >JSON</span
        >
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >VSCode</span
        >
        <span
          class="bg-white/10 text-primary text-xs font-medium px-3 py-1 rounded-full"
          >Theme</span
        >
      </div>

      <p class="text-secondary mb-6 leading-relaxed text-sm">
        Theme focused on legibility and a calm color palette for long coding
        sessions. Supports light and dark modes with multiple color variants.
      </p>

      <div class="flex gap-3">
        <a
          href="https://marketplace.visualstudio.com/items?itemName=winterx64.winteriscoding"
          target="_blank"
          class="px-4 py-2 rounded-lg bg-white/10 text-primary text-sm hover:bg-white/15 transition-colors"
        >
          Marketplace
        </a>
        <a
          href="https://github.com/winterx64/vscode-theme"
          target="_blank"
          class="px-4 py-2 rounded-lg border border-white/20 text-secondary text-sm hover:text-primary hover:border-white/30 transition-colors"
        >
          Source
        </a>
      </div>
    </article>
  </div>
</section>
