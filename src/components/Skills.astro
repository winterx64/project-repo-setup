---
---

<section id="skills" class="max-w-6xl mx-auto px-6 md:px-8 py-20">
    <div class="mb-12">
        <h2 class="text-3xl font-bold text-primary mb-4">
            Skills & Technologies
        </h2>
        <p class="text-secondary leading-relaxed text-sm max-w-2xl">
            A versatile toolkit spanning web development, embedded systems, and
            cloud technologies. I believe in using the right tool for the job
            and staying adaptable to new tech.
        </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Frontend Development -->
        <div class="p-6 rounded-2xl glass card-tilt">
            <div class="flex items-center gap-3 mb-4">
                <div class="skill-icon w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-primary">
                    <i class="fa-solid fa-palette"></i>
                </div>
                <div>
                    <h4 class="text-lg font-semibold text-primary">Frontend</h4>
                    <p class="text-xs text-tertiary">User Interface & Experience</p>
                </div>
            </div>
            <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">JavaScript</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">React</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Next.js</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">HTML/CSS</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Tailwind CSS</span>
            </div>
        </div>

        <!-- Backend Development -->
        <div class="p-6 rounded-2xl glass card-tilt">
            <div class="flex items-center gap-3 mb-4">
                <div class="skill-icon w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-primary">
                    <i class="fa-solid fa-server"></i>
                </div>
                <div>
                    <h4 class="text-lg font-semibold text-primary">Backend</h4>
                    <p class="text-xs text-tertiary">Server & Database</p>
                </div>
            </div>
            <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Python</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Flask</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Django</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">PostgreSQL</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">MongoDB</span>
            </div>
        </div>

        <!-- Hardware & IoT -->
        <div class="p-6 rounded-2xl glass card-tilt">
            <div class="flex items-center gap-3 mb-4">
                <div class="skill-icon w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-primary">
                    <i class="fa-solid fa-microchip"></i>
                </div>
                <div>
                    <h4 class="text-lg font-semibold text-primary">Hardware</h4>
                    <p class="text-xs text-tertiary">Embedded & IoT</p>
                </div>
            </div>
            <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Arduino</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">ESP32</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Raspberry Pi</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">C/C++</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Sensors</span>
            </div>
        </div>

        <!-- Tools & DevOps -->
        <div class="p-6 rounded-2xl glass card-tilt">
            <div class="flex items-center gap-3 mb-4">
                <div class="skill-icon w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-primary">
                    <i class="fa-solid fa-tools"></i>
                </div>
                <div>
                    <h4 class="text-lg font-semibold text-primary">DevOps</h4>
                    <p class="text-xs text-tertiary">Tools & Deployment</p>
                </div>
            </div>
            <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Git</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Docker</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Linux</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">CI/CD</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Nginx</span>
            </div>
        </div>

        <!-- Design & Tools -->
        <div class="p-6 rounded-2xl glass card-tilt">
            <div class="flex items-center gap-3 mb-4">
                <div class="skill-icon w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-primary">
                    <i class="fa-solid fa-paintbrush"></i>
                </div>
                <div>
                    <h4 class="text-lg font-semibold text-primary">Design</h4>
                    <p class="text-xs text-tertiary">UI/UX & Graphics</p>
                </div>
            </div>
            <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Figma</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">UX Research</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Prototyping</span>
            </div>
        </div>

        <!-- Emerging Tech -->
        <div class="p-6 rounded-2xl glass card-tilt">
            <div class="flex items-center gap-3 mb-4">
                <div class="skill-icon w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-primary">
                    <i class="fa-solid fa-rocket"></i>
                </div>
                <div>
                    <h4 class="text-lg font-semibold text-primary">Emerging</h4>
                    <p class="text-xs text-tertiary">Future Technologies</p>
                </div>
            </div>
            <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Machine Learning</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Computer Vision</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">Satellite Tech</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">AI/ML</span>
                <span class="px-3 py-1 rounded-full bg-white/10 text-primary text-xs font-medium">OpenCV</span>
            </div>
        </div>
    </div>
</section>
